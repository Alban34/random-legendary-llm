{
  "name": "legendary-marvel-randomizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./tools/dev-server.mjs",
    "start": "node ./tools/dev-server.mjs",
    "test": "node --test ./test/*.test.mjs",
    "test:epic1": "node --test ./test/epic1.test.mjs",
    "test:epic2": "node --test ./test/epic2-state.test.mjs",
    "test:epic3": "node --test ./test/epic3-setup-generator.test.mjs",
    "test:epic4": "node --test ./test/epic4-shell-navigation.test.mjs",
    "test:qc": "playwright test",
    "test:qc:headed": "playwright test --headed",
    "check:epic1": "node --test ./test/epic1.test.mjs",
    "check:epic2": "node --test ./test/epic2-state.test.mjs",
    "check:epic3": "node --test ./test/epic3-setup-generator.test.mjs",
    "check:epic4": "node --test ./test/epic4-shell-navigation.test.mjs",
    "check:qc": "playwright test",
    "report:epic1": "node ./tools/run_epic1_checks.mjs",
    "build:shell": "python3 ./tools/build_epic1_index.py",
    "build:seed": "python3 ./tools/build_epic1_seed.py"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
